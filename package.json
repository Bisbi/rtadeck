{
  "name": "rtadeck",
  "version": "0.1.0",
  "description": "Retro 8-bit Stream Deck for touch screens and smartphones",
  "type": "module",
  "bin": {
    "rtadeck": "./bin/rtadeck.js"
  },
  "files": [
    "bin/",
    "server/",
    "public/",
    "rtadeck.config.schema.json"
  ],
  "scripts": {
    "start": "node bin/rtadeck.js serve",
    "dev": "node bin/rtadeck.js serve --port 3000"
  },
  "keywords": ["stream-deck", "touch", "dashboard", "retro", "8-bit"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "open": "^10.1.0",
    "qrcode": "^1.5.4",
    "ws": "^8.18.0"
  }
}
